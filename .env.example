# Zero runtime capability discovery is public and does not require credentials.
# Live paid capability calls should use a server-side Zero wallet and a strict maxPay.
ZERO_PRIVATE_KEY=
# Alternative for a managed Zero wallet session. Keep both values server-side.
ZERO_ACCESS_TOKEN=
ZERO_REFRESH_TOKEN=
ZERO_LIVE_ACTIONS=false
# Separate kill switch for binding PO email releases after an authorized phone approval.
GROUNDWORK_PO_RELEASES_ENABLED=false

# Nexla incoming-webhook source for groundwork.field_event.v1 records.
# Keep any API key in the hosted secret URL; never expose it to the browser.
NEXLA_FIELD_EVENTS_WEBHOOK_URL=

# Real inbound voice, SMS, and MMS through AgentPhone.
AGENTPHONE_API_KEY=
AGENTPHONE_AGENT_ID=
AGENTPHONE_NUMBER=
AGENTPHONE_NUMBER_ID=
AGENTPHONE_WEBHOOK_SECRET=
# Additional comma-separated CDN hosts allowed for private media downloads.
AGENTPHONE_MEDIA_HOSTS=

# Project-scoped authority and consent directory. Use E.164 phone numbers.
GROUNDWORK_PROJECT_ID=soma_drilled_shafts_001
GROUNDWORK_ALLOWED_CALLERS=
# Example shape only; replace with consented demo recipients before enabling actions.
GROUNDWORK_CONTACTS_JSON='[{"id":"crew_foreman_01","name":"Luis Martinez","role":"drilled_shaft_foreman","phone":"+14155550148","inboundConsent":true,"outboundVoiceConsent":false,"outboundSmsConsent":false,"canRequestQuotes":true,"canApprovePurchase":false,"purchaseLimitCents":0},{"id":"project_manager_01","name":"Project Manager","role":"project_manager","phone":"+14155550149","inboundConsent":true,"outboundVoiceConsent":true,"outboundSmsConsent":true,"canRequestQuotes":true,"canApprovePurchase":true,"purchaseLimitCents":2500000}]'

# Buyer identity used verbatim in vendor RFQs and purchase orders.
GROUNDWORK_BUYER_COMPANY=
GROUNDWORK_BUYER_NAME=
GROUNDWORK_BUYER_CALLBACK=
GROUNDWORK_RFQ_EMAIL=
GROUNDWORK_DELIVERY_ADDRESS=
GROUNDWORK_HPILE_GRADE=
# Keep false outside a staged demo; normal policy permits vendor calls only weekdays 8–5 Pacific.
GROUNDWORK_ALLOW_AFTER_HOURS_RFQ=false
# Demo mode replaces the real verified vendor batch with one explicitly configured test number.
GROUNDWORK_DEMO_MODE=false
GROUNDWORK_DEMO_VENDOR_NAME=
GROUNDWORK_DEMO_VENDOR_PHONE=
# Shared bearer secret for Nexla-normalized written quotes, call polling, and vendor acknowledgements.
GROUNDWORK_PROCUREMENT_WEBHOOK_TOKEN=
GROUNDWORK_INTERNAL_API_TOKEN=

# Supabase server-only call-data store. Prefer the current sb_secret_ key;
# service_role remains supported for older projects. Never expose either key.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase browser/SSR identity. The publishable key is intentionally public;
# RLS must still deny browser access to call transcripts and procurement data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Used only by the one-time webhook configuration script.
GROUNDWORK_PUBLIC_URL=https://groundwork-field-ops.jonanrones.chatgpt.site
AGENTPHONE_WEBHOOK_SECRET_FILE=.agentphone-webhook-secret
